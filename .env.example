# =============================================================================
# White-Ops Enterprise Configuration
# Copy this file to .env and fill in your values
# =============================================================================

# ---- General ----
APP_NAME=white-ops
APP_ENV=production
SECRET_KEY=change-me-to-a-random-string-at-least-32-chars
DEBUG=false

# ---- Database ----
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=whiteops
POSTGRES_USER=whiteops
POSTGRES_PASSWORD=change-me

# ---- Redis ----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change-me

# ---- MinIO (S3-compatible file storage) ----
MINIO_ROOT_USER=whiteops
MINIO_ROOT_PASSWORD=change-me-min-8-chars
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=whiteops-files
MINIO_USE_SSL=false

# ---- LLM Providers (configure at least one) ----
# Anthropic Claude
ANTHROPIC_API_KEY=

# OpenAI GPT
OPENAI_API_KEY=

# Google Gemini
GOOGLE_API_KEY=

# Ollama (local LLM - no key needed)
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Default LLM provider: anthropic, openai, google, ollama
DEFAULT_LLM_PROVIDER=anthropic
DEFAULT_LLM_MODEL=claude-sonnet-4-20250514

# ---- Authentication ----
JWT_SECRET_KEY=change-me-to-a-different-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
ADMIN_EMAIL=admin@whiteops.local
ADMIN_PASSWORD=change-me-strong-password

# ---- Security ----
PASSWORD_MIN_LENGTH=12
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15
MFA_ENABLED=false
ALLOWED_IPS=
REQUEST_BODY_MAX_SIZE_MB=10

# ---- Rate Limiting ----
RATE_LIMIT_PER_IP=120
RATE_LIMIT_PER_USER=300
RATE_LIMIT_WINDOW_SECONDS=60

# ---- Secrets Vault ----
# Leave empty to auto-generate (not recommended for production)
VAULT_MASTER_KEY=

# ---- Internal Mail ----
MAIL_SERVER_HOST=mail
MAIL_SERVER_PORT=8025
MAIL_DOMAIN=whiteops.local

# ---- External Email (optional) ----
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@yourcompany.com
SMTP_USE_TLS=true

# ---- Worker ----
WORKER_NAME=worker-01
WORKER_MAX_AGENTS=5
MASTER_URL=http://server:8000

# ---- Integrations (optional) ----
# Slack
SLACK_BOT_TOKEN=
SLACK_WEBHOOK_URL=

# GitHub
GITHUB_TOKEN=

# Jira
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=

# Telegram
TELEGRAM_BOT_TOKEN=

# Discord
DISCORD_BOT_TOKEN=

# Notion
NOTION_API_KEY=

# Twilio SMS
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# PagerDuty
PAGERDUTY_API_KEY=

# Sentry
SENTRY_DSN=

# Linear
LINEAR_API_KEY=

# ---- Cloud Providers (optional) ----
# AWS
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# Azure
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_SUBSCRIPTION_ID=

# GCP
GOOGLE_APPLICATION_CREDENTIALS=

# ---- Cost Management ----
MONTHLY_BUDGET_USD=0
BUDGET_ALERT_THRESHOLDS=80,90,100

# ---- Monitoring (optional) ----
PROMETHEUS_ENABLED=true
GRAFANA_ADMIN_PASSWORD=change-me

# ---- Network ----
SERVER_PORT=8000
WEB_PORT=3000
CORS_ORIGINS=http://localhost:3000

# ---- Translation (optional) ----
TRANSLATE_API_URL=https://libretranslate.com
TRANSLATE_API_KEY=

# ---- Google Calendar (optional) ----
GOOGLE_CALENDAR_CREDENTIALS=
