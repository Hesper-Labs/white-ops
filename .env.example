# =============================================================================
# White-Ops Configuration
# Copy this file to .env and fill in your values
# =============================================================================

# ---- General ----
APP_NAME=white-ops
APP_ENV=production
SECRET_KEY=change-me-to-a-random-string-at-least-32-chars
DEBUG=false

# ---- Database ----
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=whiteops
POSTGRES_USER=whiteops
POSTGRES_PASSWORD=change-me

# ---- Redis ----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change-me

# ---- MinIO (S3-compatible file storage) ----
MINIO_ROOT_USER=whiteops
MINIO_ROOT_PASSWORD=change-me-min-8-chars
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=whiteops-files

# ---- LLM Providers (configure at least one) ----
# Anthropic Claude
ANTHROPIC_API_KEY=

# OpenAI GPT
OPENAI_API_KEY=

# Google Gemini
GOOGLE_API_KEY=

# Ollama (local LLM - no key needed)
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Default LLM provider: anthropic, openai, google, ollama
DEFAULT_LLM_PROVIDER=anthropic
DEFAULT_LLM_MODEL=claude-sonnet-4-20250514

# ---- Auth ----
JWT_SECRET_KEY=change-me-to-a-different-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
ADMIN_EMAIL=admin@whiteops.local
ADMIN_PASSWORD=change-me

# ---- Internal Mail ----
MAIL_SERVER_HOST=mail
MAIL_SERVER_PORT=8025
MAIL_DOMAIN=whiteops.local

# ---- External Email (optional) ----
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=

# ---- Worker ----
WORKER_NAME=worker-01
WORKER_MAX_AGENTS=5
MASTER_URL=http://server:8000

# ---- Monitoring (optional) ----
PROMETHEUS_ENABLED=true
GRAFANA_ADMIN_PASSWORD=change-me

# ---- Network ----
SERVER_PORT=8000
WEB_PORT=3000
CORS_ORIGINS=http://localhost:3000
